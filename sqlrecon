#!/usr/bin/env bash

# =========================================================
# SQLRecon Pro — SQL Injection Reconnaissance Crawler
# Created by Surya — The Cyber Conqueror
# =========================================================

set -euo pipefail

# ================= COLORS =================
RED="\e[31m"
GREEN="\e[32m"
YELLOW="\e[33m"
BLUE="\e[34m"
CYAN="\e[36m"
BOLD="\e[1m"
RESET="\e[0m"

# ================= CONFIG =================
MAX_LINKS=300
TIMEOUT=8
USER_AGENT="Mozilla/5.0 (X11; Linux x86_64) SQLReconPro/1.0"

declare -A VISITED
declare -A QUEUED

FOUND=0
CRAWLED=0

# ================= BANNER =================
banner() {
echo -e "${CYAN}${BOLD}"
cat << "EOF"

   _____ ____  __    ____                           
  / ___// __ \/ /   / __ \___  _________  ____      
  \__ \/ / / / /   / /_/ / _ \/ ___/ __ \/ __ \     
 ___/ / /_/ / /___/ _, _/  __/ /__/ /_/ / / / /     
/____/\___\_\_____/_/ |_|\___/\___/\____/_/ /_/      

      SQL Injection Reconnaissance Framework
          Created by Surya — Cyber Conqueror

EOF
echo -e "${RESET}"
}

# ================= USAGE =================
usage() {
echo
echo "Usage:"
echo "  sqlrecon -u <url>"
echo
echo "Example:"
echo "  sqlrecon -u https://example.com"
echo
exit 1
}

# ================= URL NORMALIZATION =================
normalize_url() {

local url="$1"

# remove fragments
url="${url%%#*}"

# remove duplicate slashes
url=$(echo "$url" | sed 's#//*#/#g' | sed 's#:/#://#')

# remove trailing slash
[[ "$url" != "/" ]] && url="${url%/}"

echo "$url"
}

# ================= ABSOLUTE URL RESOLVER =================
resolve_url() {

local current="$1"
local link="$2"

# absolute
if [[ "$link" =~ ^https?:// ]]; then
echo "$link"
return
fi

# protocol-relative
if [[ "$link" =~ ^// ]]; then
echo "${BASE_SCHEME}:$link"
return
fi

# root-relative
if [[ "$link" =~ ^/ ]]; then
echo "${BASE_ROOT}${link}"
return
fi

# relative paths
python3 - <<EOF
from urllib.parse import urljoin
print(urljoin("$current", "$link"))
EOF
}

# ================= VALIDATION =================
is_same_domain() {

local host
host=$(echo "$1" | awk -F/ '{print $3}')

[[ "$host" == "$BASE_HOST" ]]
}

# ================= SQL PARAM DETECTION =================
detect_sqli_params() {

local url="$1"

if echo "$url" | grep -Eqi '\?.*=[0-9]+(&|$)'; then

echo -e "${RED}${BOLD}[POTENTIAL SQLi PARAM]${RESET} $url"

((FOUND++))

fi
}

# ================= FETCH HTML =================
fetch_html() {

curl -skL \
--connect-timeout 4 \
--max-time "$TIMEOUT" \
-A "$USER_AGENT" \
"$1" 2>/dev/null | tr -d '\000'
}

# ================= CONTENT TYPE =================
is_html() {

local type

type=$(curl -skI \
--connect-timeout 4 \
--max-time "$TIMEOUT" \
-A "$USER_AGENT" \
"$1" 2>/dev/null | tr -d '\r')

echo "$type" | grep -qi "text/html"
}

# ================= LINK EXTRACTION =================
extract_links() {

grep -Eoi '<a [^>]+href=["'"'"'][^"'"'"']+' \
| sed -E 's/.*href=["'"'"']//'
}

# ================= MAIN =================

while getopts ":u:" opt; do
case $opt in
u) START_URL="$OPTARG" ;;
*) usage ;;
esac
done

[[ -z "${START_URL:-}" ]] && usage

START_URL=$(normalize_url "$START_URL")

BASE_SCHEME=$(echo "$START_URL" | awk -F:// '{print $1}')
BASE_HOST=$(echo "$START_URL" | awk -F/ '{print $3}')
BASE_ROOT="${BASE_SCHEME}://${BASE_HOST}"

banner

echo -e "${GREEN}[TARGET]${RESET} $START_URL"
echo

QUEUE=("$START_URL")
QUEUED["$START_URL"]=1

while [[ ${#QUEUE[@]} -gt 0 && $CRAWLED -lt $MAX_LINKS ]]; do

CURRENT="${QUEUE[0]}"
QUEUE=("${QUEUE[@]:1}")

CURRENT=$(normalize_url "$CURRENT")

[[ -n "${VISITED[$CURRENT]:-}" ]] && continue

VISITED["$CURRENT"]=1

((CRAWLED++))

echo -e "${CYAN}[CRAWLING]${RESET} $CURRENT"

# check HTML
if ! is_html "$CURRENT"; then
continue
fi

HTML=$(fetch_html "$CURRENT")

[[ -z "$HTML" ]] && continue

# detect params
detect_sqli_params "$CURRENT"

# extract links
while read -r rawlink; do

[[ -z "$rawlink" ]] && continue

# skip junk
if [[ "$rawlink" =~ ^#|^javascript:|^mailto:|^tel: ]]; then
continue
fi

FULL_URL=$(resolve_url "$CURRENT" "$rawlink")
FULL_URL=$(normalize_url "$FULL_URL")

# same domain only
if ! is_same_domain "$FULL_URL"; then
continue
fi

# avoid duplicates
if [[ -z "${VISITED[$FULL_URL]:-}" && -z "${QUEUED[$FULL_URL]:-}" ]]; then

QUEUE+=("$FULL_URL")
QUEUED["$FULL_URL"]=1

fi

done < <(echo "$HTML" | extract_links)

done

echo
echo -e "${BOLD}=================================================${RESET}"
echo -e "${GREEN}[✓] Crawl Complete${RESET}"
echo -e "${CYAN}[*] Crawled URLs : $CRAWLED${RESET}"
echo -e "${CYAN}[*] Interesting Params : $FOUND${RESET}"
echo -e "${CYAN}[*] Scope : $BASE_HOST${RESET}"
echo -e "${CYAN}[*] Mode : SQL Injection Reconnaissance${RESET}"
echo -e "${BOLD}=================================================${RESET}"

echo
echo -e "${YELLOW}[NEXT STEPS]${RESET}"
echo "  • Test endpoints using sqlmap"
echo "  • Analyze requests in Burp Suite"
echo "  • Check WAF protections"
echo "  • Fuzz parameters manually"
echo
